        "output_col": "ma20_slope5"
      },
      {
        "name": "slope",
        "params": {
          "window": 20,
          "period": 10
        },
        "output_col": "ma20_slope10"
      },
      {
        "name": "slope",
        "params": {
          "window": 60,
          "period": 5
        },
        "output_col": "ma60_slope5"
